# ── Twitch чат ────────────────────────────────────────────────────────────────
TWITCH_CHANNEL=Offiners
TWITCH_BOT_USERNAME=hivs_
TWITCH_BOT_TOKEN=oauth:xxxxxxxxxxxxxxxxxxxxxxx

# ── Twitch API (нужно только если хочешь баны) ────────────────────────────────
TWITCH_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxx
TWITCH_BROADCASTER_ID=123456789
TWITCH_MODERATOR_ID=987654321
TWITCH_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxx

# ── StreamElements (нужно для очков) ─────────────────────────────────────────
# JWT токен: streamelements.com → Account → App Access Token
SE_JWT_TOKEN=xxxxxxxxxxxxxxxxxxxxxxx
# ID канала SE: streamelements.com → Dashboard → URL содержит твой ID
SE_CHANNEL_ID=xxxxxxxxxxxxxxxxxxxxxxx

# Порт (render.com подставит сам)
PORT=3000
